# Stellar Network Configuration
# Options: "testnet" | "mainnet" (default: "testnet")
STELLAR_NETWORK=testnet

# Horizon Server URL (leave empty to use default for selected network)
STELLAR_HORIZON_URL=

# Soroban RPC URL (leave empty to use default for selected network)
STELLAR_SOROBAN_RPC_URL=

# Request timeout in milliseconds (default: 30000)
STELLAR_TIMEOUT=30000

# Soroban contract ID (56-char base32, starts with 'C')
STELLAR_CONTRACT_ID=

# ⚠️  NEVER commit real secret keys!
# These are only used in examples and should be set per-environment.
# SOURCE_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
